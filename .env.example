# Database Config
DATABASE_URL=postgresql://borges:borgespassword@localhost:5432/borges_os

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# LLM Providers (OpenAI Default)
OPENAI_API_KEY=sua-chave-openai-aqui
LLM_MODEL=gpt-4.1-mini

# Public URL (Evolution -> Borges OS webhook)
PUBLIC_BASE_URL=http://localhost:8000

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=global-api-key-evolution

# Bootstrap (first run)
# Set SEED_ADMIN_ON_STARTUP=true only for dev/staging. In prod, prefer creating users explicitly.
SEED_ADMIN_ON_STARTUP=true
DEFAULT_TENANT_NAME=Sede Borges OS - Admin
DEFAULT_ADMIN_EMAIL=admin@borges.com
DEFAULT_ADMIN_PASSWORD=admin123456
DEFAULT_ADMIN_FULL_NAME=Borges Super Admin

# Security
SECRET_KEY=sua-chave-secreta-muito-segura-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
